import pandas as pd

df = pd.read_csv('Dataset.csv')


df.head()


df.info()


df.shape


df.columns


df_new = df[['Restaurant Name', 'City', 'Cuisines',
                  'Average Cost for two', 'Price range',
                  'Aggregate rating', 'Votes']].copy()


df_new.info()


df_new['Cuisines'] =df_new['Cuisines'].fillna(df_new['Cuisines'].mode()[0])


df_new.info()


df_new['Cuisines'] = df_new['Cuisines'].str.lower()
df_new['City'] = df_new['City'].str.lower()


def recommend_restaurants(df_new, df, city, cuisine, price):
    
    # filter data
    filtered = df_new[
        (df_new['City'] == city.lower()) &
        (df_new['Cuisines'].str.contains(cuisine.lower(), na=False)) &
        (df_new['Price range'] == price)
    ]

    # sort by rating & votes
    filtered = filtered.sort_values(
        by=['Aggregate rating', 'Votes'],
        ascending=False
    ).head(5)

    # full details laane ke liye merge
    result = df[df['Restaurant Name'].isin(filtered['Restaurant Name'])]

    return result[['Restaurant Name', 'City', 'Cuisines',
                   'Average Cost for two', 'Aggregate rating',
                   'Votes', 'Address']]


user_city = "indore"
user_cuisine = "chinese"
user_price = 2

recommendations = recommend_restaurants(df_new,df,user_city,user_cuisine,user_price)

recommendations



